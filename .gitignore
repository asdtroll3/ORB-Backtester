# ─── Data files & generated reports (keep the repo lightweight) ───
# Price data is large and licensed — users supply their own. Reports/trades
# are regenerated on every run, so they don't belong in version control.
*.csv
*.html

# ─── Python ───
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.ipynb_checkpoints/

# ─── Virtual environments ───
.venv/
venv/
env/
ENV/

# ─── IDE / editor / OS ───
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db
